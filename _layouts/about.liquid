---
layout: default
---

{% if page.hero %}
<div class="hero-section">
  <div class="hero-content">
    <h1>{{ page.hero_title }}</h1>
    <p>{{ page.hero_subtitle }}</p>

    {% if page.hero_tags %}
    <div class="hero-tags">
      {% for tag in page.hero_tags %}
        <span>{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      Edgar Hernando <span class="font-weight-bold">Sepúlveda-Oviedo</span>
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {{ content }}

    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}
  </article>
</div>