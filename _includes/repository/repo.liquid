{% assign repo_url = include.repository | split: '/' %}

<div class="repo p-3 text-center border rounded">
  <a href="https://github.com/{{ include.repository }}" target="_blank" rel="noopener noreferrer">
    <i class="fab fa-github fa-3x mb-3"></i>
    <h5>{{ repo_url[1] }}</h5>
  </a>

  <p class="mb-1">
    <strong>{{ repo_url[0] }}/{{ repo_url[1] }}</strong>
  </p>

  <p class="small text-muted">
    Open-source scientific repository hosted on GitHub.
  </p>
</div>